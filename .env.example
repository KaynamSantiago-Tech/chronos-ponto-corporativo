# Copie para .env.local em apps/web e apps/api com valores reais

# ========== Web (apps/web/.env.local) ==========
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_SENTRY_DSN=

# ========== API (apps/api/.env) ==========
NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midrah_ponto?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/midrah_ponto?schema=public

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_JWKS_URL=https://xxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json

# CORS
WEB_ORIGIN=http://localhost:3000

# Storage
SUPABASE_STORAGE_BUCKET=evidencias

# Roleta (stub)
ROLETA_WEBHOOK_SECRET=change-me

# Observability
SENTRY_DSN=
