# Supabase — valores do dashboard do projeto
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_JWT_ISSUER="https://xxxx.supabase.co/auth/v1"
SUPABASE_JWKS_URL="https://xxxx.supabase.co/auth/v1/.well-known/jwks.json"
SUPABASE_STORAGE_BUCKET="evidencias"

# Postgres (Prisma)
# Pooled connection (PgBouncer) — usar em runtime
DATABASE_URL="postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — usar apenas em migrations
DIRECT_URL="postgresql://postgres.xxxx:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Servidor
PORT=3333
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Sentry
SENTRY_DSN=""

# Roleta (fase futura)
ROLETA_WEBHOOK_SECRET="troque-em-producao"
