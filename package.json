{
  "name": "midrah-ponto",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema interno de ponto e controle de acesso da Midrah",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rimraf dist .next node_modules && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.6.3"
  }
}
